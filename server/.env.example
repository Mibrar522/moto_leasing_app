HOST=0.0.0.0
PORT=6001
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=127.0.0.1
DB_DATABASE=motor_leasing_db
DB_PORT=5432
JWT_SECRET=your_enterprise_secret_key
CORS_ORIGIN=http://YOUR_FRONTEND_IP:5173,http://127.0.0.1:5173,http://localhost:5173
PG_DUMP_PATH=C:\Program Files\PostgreSQL\17\bin\pg_dump.exe

# Optional SMTP (used for certain server notifications). Fill later with app password.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# Customer mobile app auth/OTP
CUSTOMER_OTP_TTL_MINUTES=5
# Dev only: echoes OTP in response (never enable in production)
CUSTOMER_OTP_ECHO=false
CUSTOMER_JWT_EXPIRES_IN=30d
